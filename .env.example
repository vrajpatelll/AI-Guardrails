# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Mandatory ──────────────────────────────────────────────────────────────
# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Auth token for the guardrail endpoint — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
GUARDRAIL_TOKEN=your-guardrail-auth-token-here

# ── Optional — LLM ─────────────────────────────────────────────────────────
# Default: claude-3-5-haiku-20241022  (fast + cheap for demos)
# GUARDRAIL_MODEL=claude-3-5-sonnet-20241022

# ── Optional — Policy ──────────────────────────────────────────────────────
# Default: policy.yaml (in repo root)
# GUARDRAIL_POLICY_PATH=policy.yaml

# ── Optional — Cache ───────────────────────────────────────────────────────
# Verdict cache TTL in seconds. Default: 300
# GUARDRAIL_CACHE_TTL=300

# ── Optional — Reliability ─────────────────────────────────────────────────
# fail_open (allow on timeout) | fail_closed (block on timeout). Default: fail_open
# GUARDRAIL_FAIL_MODE=fail_open

# ── Optional — Observability ───────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR. Default: INFO
# GUARDRAIL_LOG_LEVEL=INFO

# ── Optional — Tier 2 (Qwen3Guard) ────────────────────────────────────────
# HuggingFace model ID for the Tier 2 safety classifier.
# Default: Qwen/Qwen2.5-0.5B-Instruct (~500MB download on first use)
# Swap to a larger model if a GPU is available for better accuracy.
# TIER2_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct

# Where HuggingFace caches downloaded model weights.
# Default: ~/.cache/huggingface  (set to a fast local SSD path for speed)
# HF_HOME=C:/path/to/hf_cache
